# =============================================================================
# Her-Ashtra-API — environment template
# Copy to `.env` and fill in real values for local development.
# `.env` is git-ignored. Do NOT commit secrets.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
PORT=4000

# --- JWT ----------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-strong-random-secret

# --- Database -----------------------------------------------------------
# ONE shared Neon project for the whole backend (not one per feature/person —
# see drizzle.config.ts for why). See NEON_KOYEB_DEPLOYMENT.md (in the
# frontend repo) for how to create it and run its migration.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- CORS ---------------------------------------------------------------
# Comma-separated list of full origins allowed to call this API from a browser.
# The Expo app itself (native) is not subject to CORS, but Expo Web dev mode is.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
